{
  "$schema": "https://opencode.ai/theme.json",
  "name": "Void Swarm",
  "description": "Thème par défaut Void-Swarm — cyan/violet sur fond terminal",
  "defs": {
    "swarm_cyan":      "#00FFD1",
    "swarm_cyan_dim":  "#00B894",
    "swarm_purple":    "#7C3AED",
    "swarm_purple_dim":"#5B21B6",
    "swarm_pink":      "#F472B6",
    "swarm_amber":     "#FBBF24",
    "swarm_red":       "#EF4444",
    "swarm_green":     "#10B981",
    "swarm_fg":        "#E5E7EB",
    "swarm_fg_dim":    "#9CA3AF",
    "swarm_fg_muted":  "#6B7280",
    "swarm_bg":        "none",
    "swarm_bg_panel":  "#0F172A"
  },
  "theme": {
    "primary":     { "dark": "swarm_cyan",      "light": "swarm_cyan_dim" },
    "secondary":   { "dark": "swarm_purple",    "light": "swarm_purple_dim" },
    "accent":      { "dark": "swarm_pink",      "light": "swarm_pink" },
    "text":        { "dark": "swarm_fg",        "light": "swarm_fg" },
    "textMuted":   { "dark": "swarm_fg_muted",  "light": "swarm_fg_muted" },
    "background":  { "dark": "swarm_bg",        "light": "swarm_bg" },
    "border":      { "dark": "swarm_purple_dim","light": "swarm_purple_dim" },
    "selection":   { "dark": "swarm_purple",    "light": "swarm_purple_dim" },
    "success":     { "dark": "swarm_green",     "light": "swarm_green" },
    "warning":     { "dark": "swarm_amber",     "light": "swarm_amber" },
    "error":       { "dark": "swarm_red",       "light": "swarm_red" },
    "info":        { "dark": "swarm_cyan",      "light": "swarm_cyan_dim" }
  }
}
