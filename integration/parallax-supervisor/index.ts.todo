import { spawn, type ChildProcess } from "node:child_process"

export interface SupervisorOptions {
  /** URL du scheduler Aircarto, ex: "https://swarm.aircarto.fr" */
  scheduler: string
  /** Modèle à servir, ex: "qwen-coder-32b" */
  model?: string
  /** Chemin custom vers le binaire parallax (sinon auto-détecté dans PATH) */
  binaryPath?: string
  /** Limite de VRAM dédiée au worker, ex: "12GB" ou "auto" */
  vramLimit?: string
  /** Callback de statut (joined, leaving, error...) */
  onStatus?: (status: SupervisorStatus) => void
}

export type SupervisorStatus =
  | { kind: "starting" }
  | { kind: "joined"; peerId: string }
  | { kind: "error"; error: Error }
  | { kind: "stopping" }
  | { kind: "stopped"; exitCode: number | null }

export interface SupervisorHandle {
  process: ChildProcess
  stop: () => Promise<void>
}

