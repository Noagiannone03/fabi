{
  "name": "@noagiannone03/fabi",
  "version": "0.1.0",
  "description": "CLI agentique Fabi : ouvre le fork OpenCode préconfiguré et rejoint le swarm Fabi",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "fabi": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node script/copy-assets.mjs",
    "bundle:local": "npm run build && node script/copy-opencode-runtime.mjs",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
