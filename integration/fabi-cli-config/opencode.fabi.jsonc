// Configuration opencode pré-baker pour Fabi.
//
// Ce fichier déclare le **provider Fabi** (= scheduler Aircarto, OpenAI-compatible)
// et le pose comme modèle par défaut. Le launcher fabi-launcher poste l'env var
// OPENCODE_CONFIG vers ce fichier au moment de spawn opencode, donc l'utilisateur
// final n'a rien à configurer.
//
// La config user (~/.config/opencode/opencode.json) est mergée par-dessus, donc
// l'utilisateur peut surcharger : ajouter sa clé OpenAI, changer le modèle par
// défaut, désactiver le provider Fabi avec `"disabled_providers": ["fabi"]`, etc.
//
// On ne patche AUCUN fichier source d'opencode → zéro diff vs upstream.
{
  "$schema": "https://opencode.ai/config.json",

  "provider": {
    "fabi": {
      "id":   "fabi",
      "name": "Fabi (Aircarto Swarm)",
      "npm":  "@ai-sdk/openai-compatible",
      "api":  "http://37.59.98.16:3001/v1",
      "options": {
        // Le scheduler Parallax accepte l'auth ouverte pour l'instant. On passe
        // une clé placeholder car le SDK openai-compatible exige souvent une
        // valeur non-vide pour le header Authorization.
        "apiKey": "fabi-no-auth",
        // Inférence distribuée → des shards transitent peer-à-peer, donc plus
        // lent qu'une API cloud. 10 minutes de timeout pour laisser de la marge.
        "timeout": 600000,
        // Si aucun chunk n'arrive pendant 60s, on annule (sinon un peer mort
        // bloquerait la requête indéfiniment).
        "chunkTimeout": 60000
      },
      "models": {
        "Qwen/Qwen3-Coder-30B-A3B-Instruct": {
          "id":   "Qwen/Qwen3-Coder-30B-A3B-Instruct",
          "name": "Qwen3 Coder 30B (A3B Instruct) — via Fabi swarm",
          "family": "qwen",
          "tool_call":   true,
          "reasoning":   false,
          "temperature": true,
          "modalities": { "input": ["text"], "output": ["text"] },
          "limit": { "context": 32768, "output": 8192 }
        }
      }
    }
  },

  "model":       "fabi/Qwen/Qwen3-Coder-30B-A3B-Instruct",
  "small_model": "fabi/Qwen/Qwen3-Coder-30B-A3B-Instruct"
}
