export interface SchedulerConfig {
  /** URL de base du scheduler Aircarto. Doit finir sans trailing slash. */
  schedulerUrl: string
  /** Modèle à utiliser par défaut. */
  defaultModel: string
  /** Headers additionnels à envoyer (auth, telemetry…). */
  headers: Record<string, string>
}

/**
 * Défauts hardcodés Void-Swarm production.
 * Ils sont écrasés par variables d'env / fichiers de config user.
 */
export const voidSwarmDefaults: SchedulerConfig = {
  schedulerUrl: "https://swarm.aircarto.fr",
  defaultModel: "qwen-coder-32b",
  headers: {
    "X-Void-Swarm-Client": "void-swarm-cli/0.1.0",
  },
}

export interface ResolveOptions {
  /** argv du process si on veut parser --scheduler / --model */
  argv?: string[]
  /** Chemin custom vers le fichier de config user (override) */
  userConfigPath?: string
}

/**
 * Résout la config selon les sources (CLI > env > fichier user > fichier projet > défauts).
 */
export async function resolveSchedulerConfig(
  _opts: ResolveOptions = {},
): Promise<SchedulerConfig> {
  // TODO phase 2 :
  //  1. Lire défauts
  //  2. Merger avec ~/.config/void-swarm/config.json (si existe)
  //  3. Merger avec ./.void-swarm/config.json (cwd, si existe)
  //  4. Merger avec env VOID_SWARM_SCHEDULER, VOID_SWARM_MODEL
  //  5. Merger avec argv (si présent)
  //  6. Valider : URL bien formée, modèle non vide
  return { ...voidSwarmDefaults }
}
